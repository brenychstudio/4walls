import { useEffect, useMemo, useRef, useState } from "react";

import { ACT03_BRANCH_MEDIA } from "../projectMedia";
import type { ChoiceId } from "../storyTypes";

type TransitionPhase = "entry" | "rupture" | "reveal" | "dissolve";

type Props = {
  choice: ChoiceId;
  onCommit: (choice: ChoiceId) => void;
  onFinish: () => void;
};

const TIMINGS = {
  ruptureAt: 360,
  revealAt: 1260,
  commitAt: 1660,
  dissolveAt: 2060,
  finishAt: 2720,
} as const;

export default function BranchVideoTransition({ choice, onCommit, onFinish }: Props) {
  const [phase, setPhase] = useState<TransitionPhase>("entry");
  const committedRef = useRef(false);
  const videoRef = useRef<HTMLVideoElement | null>(null);

  const asset = useMemo(() => ACT03_BRANCH_MEDIA[choice], [choice]);

  useEffect(() => {
    const video = videoRef.current;
    if (!video) return;

    video.currentTime = 0;

    const playPromise = video.play();
    if (playPromise && typeof playPromise.catch === "function") {
      playPromise.catch(() => {
        // muted preview autoplay can still be deferred by some browsers
      });
    }
  }, [choice]);

  useEffect(() => {
    const t1 = window.setTimeout(() => setPhase("rupture"), TIMINGS.ruptureAt);
    const t2 = window.setTimeout(() => setPhase("reveal"), TIMINGS.revealAt);
    const t3 = window.setTimeout(() => {
      if (!committedRef.current) {
        committedRef.current = true;
        onCommit(choice);
      }
    }, TIMINGS.commitAt);
    const t4 = window.setTimeout(() => setPhase("dissolve"), TIMINGS.dissolveAt);
    const t5 = window.setTimeout(() => onFinish(), TIMINGS.finishAt);

    return () => {
      window.clearTimeout(t1);
      window.clearTimeout(t2);
      window.clearTimeout(t3);
      window.clearTimeout(t4);
      window.clearTimeout(t5);
      committedRef.current = false;
    };
  }, [choice, onCommit, onFinish]);

  const stageOpacity =
    phase === "entry" ? 1 : phase === "rupture" ? 1 : phase === "reveal" ? 1 : 0;
  const cardOpacity =
    phase === "entry" ? 1 : phase === "rupture" ? 0.72 : phase === "reveal" ? 0.12 : 0;
  const cardTransform =
    phase === "entry"
      ? "translateY(0px) scale(1)"
      : phase === "rupture"
      ? "translateY(-8px) scale(1.025)"
      : phase === "reveal"
      ? "translateY(-20px) scale(1.05)"
      : "translateY(-28px) scale(1.08)";
  const blackoutOpacity =
    phase === "entry" ? 0.68 : phase === "rupture" ? 0.82 : phase === "reveal" ? 0.18 : 0;

  return (
    <div
      className="fixed inset-0 z-[150] overflow-hidden bg-black"
      style={{
        opacity: stageOpacity,
        transition: "opacity 420ms ease",
      }}
    >
      <div className="absolute inset-0 bg-black" style={{ opacity: blackoutOpacity }} />

      <VideoPreview choice={choice} src={asset.src} phase={phase} videoRef={videoRef} />

      <BranchMask choice={choice} phase={phase} />

      <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(126,255,186,0.12),transparent_42%)]" />

      <div className="relative z-10 flex min-h-screen items-center justify-center px-6">
        <div
          className="w-full max-w-[720px] rounded-[28px] border border-white/10 bg-[rgba(8,14,11,0.56)] px-6 py-6 text-left shadow-[0_0_90px_rgba(0,0,0,0.28)] backdrop-blur-xl transition-all duration-500 md:px-8"
          style={{
            opacity: cardOpacity,
            transform: cardTransform,
          }}
        >
          <div className="text-[10px] uppercase tracking-[0.32em] text-[rgba(176,255,206,0.48)]">
            selected route
          </div>

          <h2 className="mt-4 text-[clamp(24px,3vw,42px)] leading-[1.08] text-[rgba(242,255,246,0.94)]">
            {asset.title}
          </h2>

          <p className="mt-4 max-w-[560px] text-[14px] leading-[1.8] text-[rgba(208,255,222,0.62)]">
            {asset.summary}
          </p>

          <div className="mt-6 text-[11px] uppercase tracking-[0.28em] text-[rgba(170,255,198,0.34)]">
            entering scene...
          </div>
        </div>
      </div>
    </div>
  );
}

function VideoPreview({
  choice,
  src,
  phase,
  videoRef,
}: {
  choice: ChoiceId;
  src: string;
  phase: TransitionPhase;
  videoRef: React.RefObject<HTMLVideoElement | null>;
}) {
  const opacity =
    choice === "door"
      ? 1
      : phase === "entry"
      ? 0.16
      : phase === "rupture"
      ? 0.38
      : phase === "reveal"
      ? 0.92
      : 0.18;

  const filter = getPreviewFilter(choice, phase);
  
  const transform =
    choice === "phone"
      ? phase === "entry"
        ? "scale(1.02)"
        : phase === "rupture"
        ? "scale(1.03)"
        : "scale(1)"
      : "scale(1)";

  return (
    <div className="absolute inset-0 overflow-hidden">
      <video
        ref={videoRef}
        key={`${choice}-${src}`}
        className="absolute inset-0 h-full w-full object-cover"
        src={src}
        autoPlay
        loop
        muted
        playsInline
        preload="auto"
        style={{
          opacity,
          filter,
          transform,
          objectPosition: "50% 50%",
          transition:
            "opacity 900ms ease, filter 1600ms cubic-bezier(0.22,1,0.36,1), transform 1600ms cubic-bezier(0.22,1,0.36,1)",
        }}
      />

      {choice === "phone" ? <PhoneSignalLayers phase={phase} /> : null}
      {choice === "wash" ? <WashCondensationLayers phase={phase} /> : null}
    </div>
  );
}

function getPreviewFilter(choice: ChoiceId, phase: TransitionPhase) {
  if (choice === "door") {
    return phase === "entry"
      ? "blur(10px) brightness(0.22) saturate(0.72)"
      : phase === "rupture"
      ? "blur(5px) brightness(0.48) saturate(0.78)"
      : phase === "reveal"
      ? "blur(0px) brightness(0.96) saturate(0.92)"
      : "blur(0px) brightness(1)";
  }

  if (choice === "phone") {
    return phase === "entry"
      ? "blur(4px) brightness(0.32) contrast(1.18) saturate(0.66)"
      : phase === "rupture"
      ? "blur(1.5px) brightness(0.82) contrast(1.32) saturate(0.82)"
      : phase === "reveal"
      ? "blur(0px) brightness(1) contrast(1.08) saturate(0.94)"
      : "blur(0px) brightness(1)";
  }

  return phase === "entry"
    ? "blur(34px) brightness(0.28) saturate(0.58)"
    : phase === "rupture"
    ? "blur(22px) brightness(0.46) saturate(0.68)"
    : phase === "reveal"
    ? "blur(4px) brightness(0.94) saturate(0.9)"
    : "blur(0px) brightness(1)";
}

function BranchMask({
  choice,
  phase,
}: {
  choice: ChoiceId;
  phase: TransitionPhase;
}) {
  if (choice === "door") {
    const apertureSize =
      phase === "entry"
        ? 34
        : phase === "rupture"
        ? 78
        : phase === "reveal"
        ? 2200
        : 2600;

    const shadowOpacity =
      phase === "entry"
        ? 0.995
        : phase === "rupture"
        ? 0.995
        : phase === "reveal"
        ? 0.08
        : 0;

    const rimOpacity =
      phase === "entry"
        ? 0.22
        : phase === "rupture"
        ? 0.4
        : phase === "reveal"
        ? 0.04
        : 0;

    const centerGlowOpacity =
      phase === "entry"
        ? 0.08
        : phase === "rupture"
        ? 0.14
        : phase === "reveal"
        ? 0.03
        : 0;

    return (
      <div className="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div
          className="relative rounded-full transition-all duration-[2100ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
          style={{
            width: `${apertureSize}px`,
            height: `${apertureSize}px`,
            border: `1px solid rgba(228,255,236,${rimOpacity * 0.42})`,
            boxShadow: `
            0 0 0 200vmax rgba(0,0,0,${shadowOpacity}),
            inset 0 0 42px rgba(0,0,0,0.46),
            0 0 24px rgba(210,255,226,${rimOpacity * 0.18})
          `,
            background: "transparent",
          }}
        >
          <div
            className="absolute inset-0 rounded-full"
            style={{
              opacity: centerGlowOpacity,
              background:
                "radial-gradient(circle at 50% 50%, rgba(210,255,226,0.16), transparent 58%)",
              transition: "opacity 1600ms ease",
            }}
          />
        </div>
      </div>
    );
  }

  if (choice === "phone") {
    const bandTranslate =
      phase === "entry"
        ? "28vh"
        : phase === "rupture"
        ? "0vh"
        : phase === "reveal"
        ? "-12vh"
        : "-18vh";

    const bandOpacity =
      phase === "entry"
        ? 0.08
        : phase === "rupture"
        ? 0.36
        : phase === "reveal"
        ? 0.1
        : 0;

    const pulseOpacity =
      phase === "entry"
        ? 0
        : phase === "rupture"
        ? 0.24
        : phase === "reveal"
        ? 0.06
        : 0;

    return (
      <div className="absolute inset-0 overflow-hidden">
        <div
          className="absolute inset-0 mix-blend-screen transition-opacity duration-500"
          style={{
            opacity: pulseOpacity,
            background:
              "radial-gradient(circle at 50% 50%, rgba(230,255,236,0.52), rgba(130,255,188,0.18) 34%, transparent 62%)",
          }}
        />

        <div
          className="absolute left-[-10%] top-1/2 h-[20vh] w-[120%] -translate-y-1/2 blur-[16px] transition-all duration-700"
          style={{
            opacity: bandOpacity,
            transform: `translateY(${bandTranslate})`,
            background:
              "linear-gradient(90deg, transparent, rgba(224,255,235,0.82), rgba(126,255,190,0.26), transparent)",
          }}
        />

        <div
          className="absolute inset-0 transition-opacity duration-500"
          style={{
            opacity: phase === "rupture" ? 0.18 : phase === "reveal" ? 0.06 : 0,
            background:
              "repeating-linear-gradient(180deg, rgba(235,255,240,0.08) 0px, rgba(235,255,240,0.08) 1px, transparent 2px, transparent 5px)",
            mixBlendMode: "screen",
          }}
        />
      </div>
    );
  }

  const veilOpacity =
    phase === "entry"
      ? 0.52
      : phase === "rupture"
      ? 0.72
      : phase === "reveal"
      ? 0.18
      : 0;

  const veilBlur =
    phase === "entry"
      ? "blur(28px)"
      : phase === "rupture"
      ? "blur(20px)"
      : phase === "reveal"
      ? "blur(6px)"
      : "blur(0px)";

  const holeStop =
    phase === "entry"
      ? "6%"
      : phase === "rupture"
      ? "16%"
      : phase === "reveal"
      ? "68%"
      : "84%";

  const edgeStop =
    phase === "entry"
      ? "18%"
      : phase === "rupture"
      ? "34%"
      : phase === "reveal"
      ? "92%"
      : "100%";

  const washSweepTransform =
    phase === "entry"
      ? "translate(-42%, -8%) rotate(-12deg)"
      : phase === "rupture"
      ? "translate(-8%, -2%) rotate(-10deg)"
      : phase === "reveal"
      ? "translate(22%, 6%) rotate(-6deg)"
      : "translate(30%, 10%) rotate(-4deg)";

  const washSweepOpacity =
    phase === "entry"
      ? 0.08
      : phase === "rupture"
      ? 0.2
      : phase === "reveal"
      ? 0.1
      : 0;

  const washMask = `radial-gradient(circle at 52% 48%, transparent 0%, transparent ${holeStop}, rgba(0,0,0,0.55) ${edgeStop}, black 100%)`;

  return (
    <div className="absolute inset-0 overflow-hidden">
      <div
        className="absolute inset-0 transition-all duration-[900ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
        style={{
          opacity: veilOpacity,
          backdropFilter: veilBlur,
          WebkitBackdropFilter: veilBlur,
          maskImage: washMask,
          WebkitMaskImage: washMask,
          background:
            "radial-gradient(circle at 28% 24%, rgba(246,255,250,0.22), transparent 18%), radial-gradient(circle at 58% 42%, rgba(246,255,250,0.14), transparent 16%), radial-gradient(circle at 74% 64%, rgba(246,255,250,0.16), transparent 18%), rgba(8,12,10,0.34)",
        }}
      />

      <div
        className="absolute left-[-12%] top-[-8%] h-[128vh] w-[72vw] transition-all duration-[900ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
        style={{
          opacity: washSweepOpacity,
          transform: washSweepTransform,
          background:
            "linear-gradient(90deg, transparent 0%, rgba(242,255,248,0.64) 46%, rgba(206,255,226,0.18) 70%, transparent 100%)",
          filter: "blur(26px)",
        }}
      />

      <div
        className="absolute inset-0 transition-opacity duration-[900ms]"
        style={{
          opacity: phase === "entry" ? 0.12 : phase === "rupture" ? 0.22 : phase === "reveal" ? 0.06 : 0,
          background:
            "radial-gradient(circle at 30% 28%, rgba(255,255,255,0.18), transparent 14%), radial-gradient(circle at 66% 38%, rgba(255,255,255,0.12), transparent 12%), radial-gradient(circle at 74% 72%, rgba(255,255,255,0.14), transparent 14%)",
        }}
      />
    </div>
  );
}

function PhoneSignalLayers({ phase }: { phase: TransitionPhase }) {
  const ghostOpacity = phase === "entry" ? 0 : phase === "rupture" ? 0.14 : phase === "reveal" ? 0.06 : 0;

  return (
    <>
      <div
        className="absolute inset-0 transition-opacity duration-500"
        style={{
          opacity: ghostOpacity,
          transform: phase === "rupture" ? "translateX(12px)" : "translateX(0px)",
          background:
            "linear-gradient(90deg, rgba(255,255,255,0.04), rgba(130,255,188,0.14), transparent 60%)",
          mixBlendMode: "screen",
        }}
      />
      <div
        className="absolute inset-0 transition-opacity duration-500"
        style={{
          opacity: ghostOpacity * 0.8,
          transform: phase === "rupture" ? "translateX(-14px)" : "translateX(0px)",
          background:
            "linear-gradient(90deg, transparent 30%, rgba(255,255,255,0.08), rgba(98,255,172,0.12), transparent 84%)",
          mixBlendMode: "screen",
        }}
      />
    </>
  );
}

function WashCondensationLayers({ phase }: { phase: TransitionPhase }) {
  return (
    <div
      className="absolute inset-0 transition-opacity duration-700"
      style={{
        opacity: phase === "entry" ? 0.16 : phase === "rupture" ? 0.28 : phase === "reveal" ? 0.08 : 0,
        background:
          "radial-gradient(circle at 24% 30%, rgba(248,255,252,0.18), transparent 20%), radial-gradient(circle at 58% 40%, rgba(248,255,252,0.12), transparent 18%), radial-gradient(circle at 78% 64%, rgba(248,255,252,0.14), transparent 18%)",
      }}
    />
  );
}
